########################
# OS / Editor cruft
########################

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

########################
# Editors / IDEs
########################
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

########################
# Logs & temp
########################
*.log
*.tmp
*.bak
.cache/

########################
# Node / web tooling
# (only relevant if a build step is ever added — kept so generated
#  output never gets committed by accident)
########################
node_modules/
dist/
build/
.parcel-cache/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

########################
# Env / secrets
########################
.env
.env.*
!.env.example

########################
# AI tooling (local only)
########################
.claude/
.agents/
.mcp.json

########################
# IMPORTANT: Keep these tracked (do NOT ignore)
########################
# index.html              — the site itself
# google*.html            — Google Search Console verification
# README.md / CLAUDE.md   — project docs
# .gitignore
########################
